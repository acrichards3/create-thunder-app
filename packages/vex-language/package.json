{
  "name": "vex-spec",
  "displayName": "Vex spec (.vex)",
  "description": "Syntax highlighting and live validation for .vex specification files (uses workspace vexkit + Bun).",
  "version": "0.0.3",
  "private": true,
  "publisher": "vex-app",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "extension.js",
  "activationEvents": [
    "onLanguage:vex"
  ],
  "contributes": {
    "languages": [
      {
        "id": "vex",
        "aliases": [
          "Vex specification"
        ],
        "extensions": [
          ".vex"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vex",
        "path": "./syntaxes/vex.tmLanguage.json",
        "scopeName": "source.vex"
      }
    ]
  },
  "scripts": {
    "lint": "node --check extension.js"
  }
}
