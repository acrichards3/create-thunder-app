{
  "name": "cursor-feature-workflow",
  "publisher": "vex-app",
  "displayName": "Feature Workflow",
  "description": "6-step AI-assisted feature workflow with VEX spec trees - renders inside Cursor as a native IDE panel",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/extension.cjs",
  "scripts": {
    "build": "node scripts/build.js",
    "bundle": "node ../vexkit/scripts/bundle-dashboard.mjs && node scripts/copy-media.js",
    "vsce-package": "node scripts/build.js && npx @vscode/vsce package --no-dependencies --skip-license",
    "vsix": "bun run bundle && node scripts/build.js && npx @vscode/vsce package --no-dependencies --allow-missing-repository --skip-license",
    "vsix:install": "bun run vsix && cursor --install-extension ./cursor-feature-workflow-0.0.1.vsix"
  },
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:feature-workflow.open"
  ],
  "contributes": {
    "commands": [
      {
        "command": "feature-workflow.open",
        "title": "Open Feature Workflow",
        "shortTitle": "Workflow"
      }
    ],
    "views": {
      "editor": [
        {
          "id": "featureWorkflow",
          "name": "Feature Workflow",
          "type": "webview"
        }
      ]
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.27.4"
  }
}
